<%- include("partials/header", { title: title }) %>

    <main>

        <h2>Edit Category</h2>

        <form action="/edit-category/<%= category.category_id %>" method="POST">

            <label for="categoryName">
                Category Name
            </label>

            <input type="text" id="categoryName" name="categoryName" value="<%= category.category_name %>"
                maxlength="100" required>

            <button type="submit">
                Update Category
            </button>

        </form>

    </main>

    <%- include("partials/footer") %>