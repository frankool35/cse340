<%- include("partials/header", { title: title }) %>

    <main>

        <h2>
            Assign Categories
        </h2>

        <h3>
            <%= projectDetails.title %>
        </h3>

        <form action="/assign-categories/<%= projectId %>" method="POST">

            <% categories.forEach(category=> { %>

                <div class="form-group">

                    <input type="checkbox" id="category-<%= category.category_id %>" name="categoryIds"
                        value="<%= category.category_id %>" <%=assignedCategories.some( assigned=>
                    assigned.category_id === category.category_id
                    ) ? "checked" : "" %>
                    >

                    <label for="category-<%= category.category_id %>">
                        <%= category.category_name %>
                    </label>

                </div>

                <% }) %>

                    <br>

                    <button type="submit">
                        Update Categories
                    </button>

        </form>

    </main>

    <%- include("partials/footer") %>