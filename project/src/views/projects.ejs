<%- include("partials/header", { title: title }) %>

    <main>

        <h2>
            <%= title %>
        </h2>

        <p>
            Browse the next five upcoming community service projects.
        </p>

        <section class="project-grid">

            <% projects.forEach(project=> { %>

                <article class="card">

                    <h3>
                        <a href="/project/<%= project.project_id %>">
                            <%= project.title %>
                        </a>
                    </h3>

                    <p>
                        <%= project.description %>
                    </p>

                    <p>
                        <strong>Date:</strong>
                        <%= project.date.toLocaleDateString() %>
                    </p>

                    <p>
                        <strong>Location:</strong>
                        <%= project.location %>
                    </p>

                    <p>
                        Organization:
                        <a href="/organization/<%= project.organization_id %>">
                            <%= project.organization_name %>
                        </a>
                    </p>

                </article>

                <% }) %>

        </section>

    </main>

    <%- include("partials/footer") %>